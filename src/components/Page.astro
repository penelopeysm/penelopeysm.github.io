---
const { title } = Astro.props;
const siteTitle = "penelopeysm"

import '../styles/global.css';
---

<html lang="en">
    <head>
        <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <meta charset="utf-8" />
        <title>{title} • {siteTitle}</title>
    </head>

    <body>
        <div class="wrapper">
            <header>
                <nav>
                    <div class="nav-left">
                        <a href="/">Home</a>
                    </div>
                    <div class="nav-right">
                        <a href="https://github.com/penelopeysm" target="_blank">GitHub</a>
                    </div>
                </nav>
            </header>

            <main>
                <slot />
            </main>

            <footer>
                <span>&copy; {new Date().getFullYear()} Penelope Yong</span>
                <span class="sep">&middot;</span>
                <span>Built with <a href="https://astro.build">Astro</a></span>
            </footer>
        </div>
    </body>
</html>

<style>
    body {
        display: flex;
        justify-content: center;
        margin: 0;
        padding: 0;
        min-height: 100vh;
        background-color: #ededf6;
    }
    .wrapper {
        width: 100%;
        max-width: 860px;
        padding: 0 1.5rem;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }
    header {
        padding: 1rem 0;
        border-bottom: 1px solid #c8c8e0;
        margin-bottom: 2rem;
    }
    nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .nav-left {
        display: flex;
        align-items: center;
        gap: 1.2em;
    }
    .nav-right {
        display: flex;
        align-items: center;
    }
    nav a {
        font-size: 0.9rem;
        text-decoration: none;
        color: #5a5a7a;
    }
    nav a:hover {
        color: #0f5c52;
    }
    main {
        flex: 1;
    }
    footer {
        margin-top: 3rem;
        padding: 1.5rem 0;
        border-top: 1px solid #c8c8e0;
        font-size: 0.85rem;
        color: #6a6a8a;
    }
    .sep {
        margin: 0 0.4em;
    }
</style>
